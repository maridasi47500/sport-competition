<div id="<%= dom_id event %>">
  <p>
    <strong>Sport:</strong>
    <%= event.sport_id %>
  </p>

  <p>
    <strong>Date:</strong>
    <%= event.date %>
  </p>

  <p>
    <strong>Lieu:</strong>
    <%= event.lieu %>
  </p>

  <p>
    <strong>Lat:</strong>
    <%= event.lat %>
  </p>

  <p>
    <strong>Lon:</strong>
    <%= event.lon %>
  </p>

  <p>
    <strong>Name:</strong>
    <%= event.name %>
  </p>

  <p>
    <strong>Time:</strong>
    <%= event.time %>
  </p>

</div>
